rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "thangloi.nvy@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "admin@example.com"));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTeacher(data) {
      return hasOnlyAllowedFields(['name', 'role', 'bio', 'image', 'tags', 'quote', 'email', 'phone', 'facebook']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 100 &&
             data.bio is string && data.bio.size() < 2000 &&
             data.image is string && data.image.size() < 1048576 &&
             (!('tags' in data) || (data.tags is list && data.tags.size() < 20)) &&
             (!('quote' in data) || (data.quote is string && data.quote.size() < 500)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             (!('facebook' in data) || (data.facebook is string && data.facebook.size() < 200));
    }

    function isValidDocument(data) {
      return hasOnlyAllowedFields(['title', 'category', 'subCategory', 'url', 'type']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             (!('subCategory' in data) || (data.subCategory is string && data.subCategory.size() < 100)) &&
             data.url is string && data.url.size() > 0 && data.url.size() < 1000 &&
             data.type in ['pdf', 'doc', 'link'];
    }

    function isValidVideo(data) {
      return hasOnlyAllowedFields(['teacherName', 'title', 'embedUrl']) &&
             data.teacherName is string && data.teacherName.size() > 0 && data.teacherName.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.embedUrl is string && data.embedUrl.size() > 0 && data.embedUrl.size() < 1000;
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['role']) &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /teachers/{teacherId} {
      allow read: if true;
      allow create: if isAdmin() && isValidTeacher(request.resource.data);
      allow update: if isAdmin() && isValidTeacher(request.resource.data);
      allow delete: if isAdmin();
    }

    match /documents/{documentId} {
      allow read: if true;
      allow create: if isAdmin() && isValidDocument(request.resource.data);
      allow update: if isAdmin() && isValidDocument(request.resource.data);
      allow delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create: if isAdmin() && isValidVideo(request.resource.data);
      allow update: if isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
